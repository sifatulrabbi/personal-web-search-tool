{
    "name": "@sifatul-web-search-tool/cli",
    "version": "0.1.0",
    "description": "Terminal interface for @sifatul-web-search-tool/core — smoke-test Google search from your CLI",
    "type": "module",
    "license": "MIT",
    "bin": {
        "web-search": "./src/index.ts"
    },
    "scripts": {
        "search": "bun run src/index.ts",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "typecheck": "bun x tsc --noEmit",
        "typecheck:watch": "bun x tsc --noEmit --watch",
        "build": "bun x tsc -p src/tsconfig.build.json",
        "build:watch": "bun x tsc -p src/tsconfig.build.json --watch",
        "format": "bun x prettier --write --ignore-path ../../.prettierignore .",
        "format:check": "bun x prettier --check --ignore-path ../../.prettierignore ."
    },
    "dependencies": {
        "@sifatul-web-search-tool/core": "workspace:*"
    },
    "devDependencies": {
        "bun-types": "^1.3.14",
        "@types/bun": "catalog:",
        "@types/node": "catalog:",
        "prettier": "catalog:"
    }
}
