{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": false,
    "skipLibCheck": true,
    "target": "ES2022",
    "resolveJsonModule": true,
    "types": ["bun-types", "node"],
    "outDir": "../dist",
    "declaration": true,
    "rootDir": "."
  },
  "include": [],
  "files": [
    "index.ts",
    "browser/profile.ts",
    "browser/manager.ts",
    "search/filters.ts",
    "search/url-builder.ts",
    "search/serp.ts",
    "content/extractor.ts"
  ]
}
