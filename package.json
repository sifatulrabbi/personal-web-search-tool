{
    "name": "google-search-core",
    "version": "0.1.0",
    "description": "Programmatic Google search using your own Chrome profile on macOS",
    "type": "module",
    "license": "MIT",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "test": "bun test",
        "test:watch": "bun test --watch",
        "test:unit": "bun test tests/unit.test.ts",
        "test:integration": "GOOGLE_SEARCH_TEST=1 bun test tests/integration.test.ts",
        "typecheck": "bun x tsc --noEmit",
        "typecheck:watch": "bun x tsc --noEmit --watch",
        "build": "bun x tsc -p src/tsconfig.build.json",
        "build:watch": "bun x tsc -p src/tsconfig.build.json --watch",
        "prepack": "bun run build && bun run typecheck",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "playwright-core": "^1.49.0",
        "turndown": "^7.1.2",
        "@mozilla/readability": "^0.5.0"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "@types/node": "^25.9.3",
        "@types/turndown": "^5.0.5",
        "prettier": "^3.8.4"
    }
}
